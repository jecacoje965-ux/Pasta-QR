<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PA.STA? Table Tile</title>
    <style>
        :root {
            --bg-color: #f1e4bc; /* Boja pozadine tvog logotipa */
            --text-color: #1a1a1a;
            --accent-color: #d34a26; /* Boja paradajz sosa */
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            background-color: #f5f5f5;
            font-family: 'Helvetica', Arial, sans-serif;
        }

        /* Format 10x10 cm za sto */
        .tile {
            width: 400px;
            height: 400px;
            background-color: var(--bg-color);
            position: relative;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border-radius: 8px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px;
            box-sizing: border-box;
        }

        /* Glavni Logo */
        .logo-container {
            width: 80%;
            margin-top: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .main-logo {
            width: 100%;
            height: auto;
            object-fit: contain;
        }

        /* Donji deo sa QR kodom i tekstom */
        .bottom-section {
            position: absolute;
            bottom: 40px;
            width: 80%;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .qr-placeholder {
            width: 70px;
            height: 70px;
            background-color: white;
            padding: 5px;
            border-radius: 4px;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .qr-placeholder img {
            width: 100%;
            height: 100%;
        }

        .cta-text {
            font-size: 14px;
            color: var(--text-color);
            text-align: right;
            line-height: 1.4;
            max-width: 120px;
            font-weight: 500;
        }

        @media print {
            body { background: white; }
            .tile { box-shadow: none; border: 1px solid #ddd; }
        }
    </style>
</head>
<body>

    <div class="tile">
        <div class="logo-container">
            <img src="PA_STA_LOGO_URL_HERE.png" alt="PA.STA? Logo" class="main-logo">
        </div>

        <div class="bottom-section">
            <div class="qr-placeholder">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://www.google.com/search?q=Pa.Sta?+Reviews&si=AL3DRZEsmMGCryMMFSHJ3StBhOdZ2-6yYkXd_doETEE1OR-qObfd0y5dLc0ttufi1mHq77QTk3i74uDa0vJDRuGgT_x58p1P4LoNXpKSKsD6IORfMl-jjntVgw_3F1CelgbwpqbEbONK" alt="QR Code">
            </div>

            <div class="cta-text">
                Loved the taste?<br>
                <b>Scan to review.</b>
            </div>
        </div>
    </div>

</body>
</html>
